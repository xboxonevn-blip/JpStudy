{
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "jpstudy-v2",
          "appId": "1:129949648924:android:4e2023b729a0cb3e8337d9",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "jpstudy-v2",
          "configurations": {
            "android": "1:129949648924:android:4e2023b729a0cb3e8337d9",
            "ios": "1:129949648924:ios:ad22cf784be09a1c8337d9",
            "web": "1:129949648924:web:a4dbfa27af569b478337d9",
            "windows": "1:129949648924:web:0b2d415594a5bf5f8337d9"
          }
        }
      }
    }
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "Permissions-Policy",
            "value": "camera=(), microphone=(), geolocation=()"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
