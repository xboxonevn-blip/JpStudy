{
  "name": "jpstudy-v2",
  "version": "1.0.0",
  "description": "Web demo: https://jpstudy.web.app",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "lib": "lib",
    "test": "test"
  },
  "scripts": {
    "report:ga4-export": "node tool/research/ga4_export_status_report.js",
    "report:deletion-readiness": "node tool/research/deletion_readiness_report.js",
    "report:sentry-readiness": "node tool/research/sentry_readiness_report.js",
    "report:storage-readiness": "node tool/research/storage_readiness_report.js",
    "test:research-tooling": "node --test test/tool/research/*.js",
    "test:storage-rules": "firebase emulators:exec --only storage --project jpstudy-v2-test \"jest tooling/firebase/storage.rules.test.js --runInBand\"",
    "test:web-resource-smoke": "node tool/research/web_resource_smoke.js --build-root build/web --max-resources 80 --max-json 5 --max-grammar 0",
    "test:web-resource-smoke:unit": "node --test test/tool/research/web_resource_smoke_node_test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xboxonevn-blip/JpStudy-v2.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/xboxonevn-blip/JpStudy-v2/issues"
  },
  "homepage": "https://github.com/xboxonevn-blip/JpStudy-v2#readme",
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "firebase": "^12.13.0",
    "firebase-tools": "^15.17.0",
    "jest": "^30.4.2",
    "playwright": "^1.60.0"
  }
}
